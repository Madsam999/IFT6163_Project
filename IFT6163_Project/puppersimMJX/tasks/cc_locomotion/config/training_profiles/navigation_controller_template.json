{
  "name": "navigation_controller_template",
  "description": "Template profile for controller+navigation reward experiments. Duplicate and tune scales as needed.",
  "env_kwargs": {
    "model_path": "puppersimMJX/assets/pupper_v2_final_stable.xml",
    "urdf_path": "puppersimMJX/assets/pupper_v2a.urdf",
    "auto_generate_mjcf": false,
    "regenerate_mjcf_if_exists": false,
    "action_scale": 0.75,
    "reward_module": "puppersimMJX.tasks.cc_locomotion.reward",
    "reward_requires_command": true,
    "reward_config": {
      "tracking_sigma": 0.25,
      "feet_air_time_minimum": 0.1,
      "stand_still_command_threshold": 0.05,
      "desired_world_z_in_body_frame": [0.0, 0.0, 1.0],
      "default_pose": [0.26, 0.0, -0.52, -0.26, 0.0, 0.52, 0.26, 0.0, -0.52, -0.26, 0.0, 0.52],
      "desired_abduction_angles": [0.0, 0.0, 0.0, 0.0],
      "scales": {
        "tracking_lin_vel": 1.5,
        "tracking_ang_vel": 1.0,
        "orientation": -5.0,
        "action_rate": -0.01,
        "feet_air_time": 0.2,
        "termination": -100.0
      }
    },
    "include_command_in_obs": true,
    "observation_history": 20,
    "resample_velocity_step": 200,
    "lin_vel_x_range": [-0.6, 0.6],
    "lin_vel_y_range": [-0.3, 0.3],
    "ang_vel_yaw_range": [-1.2, 1.2],
    "healthy_z_range": [0.1, 0.6],
    "terminal_roll_pitch_threshold": 0.52,
    "termination_grace_steps": 50,
    "exclude_xy_from_obs": true
  }
}
