+"""Evaluate a saved PPO (or PPO+ICM) policy on PupperGymEnv-v0 with GUI rendering.
+
+Usage:
+    python puppersim/pupper_eval_ppo.py --model-path runs/<run_name>/pupper_train_ppo_cont_action.cleanrl_model
+
+Optional flags:
+    --num-episodes  Number of episodes to evaluate (default: 5)
+    --deterministic Use the mean action instead of sampling (default: True)
+    --no-render     Disable the PyBullet GUI (headless)
+"""
+
+import argparse
+import os
+import time
+
+import gymnasium as gym
+import numpy as np
+import torch
+import torch.nn as nn
+import puppersim
+
+
+# ---------------------------------------------------------------------------
+# Replicate the Agent architecture from training (must match exactly)
+# ---------------------------------------------------------------------------
+
+def layer_init(layer, std=np.sqrt(2), bias_const=0.0):
+    torch.nn.init.orthogonal_(layer.weight, std)
+    torch.nn.init.constant_(layer.bias, bias_const)
+    return layer
+
+
+class Agent(nn.Module):
+    def __init__(self, obs_dim: int, action_dim: int):
+        super().__init__()
+        self.critic = nn.Sequential(
+            layer_init(nn.Linear(obs_dim, 64)),
+            nn.Tanh(),
+            layer_init(nn.Linear(64, 64)),
+            nn.Tanh(),
+            layer_init(nn.Linear(64, 1), std=1.0),
+        )
+        self.actor_mean = nn.Sequential(
+            layer_init(nn.Linear(obs_dim, 64)),
+            nn.Tanh(),
+            layer_init(nn.Linear(64, 64)),
+            nn.Tanh(),
+            layer_init(nn.Linear(64, action_dim), std=0.01),
+        )
+        self.actor_logstd = nn.Parameter(torch.zeros(1, action_dim))
+
+    def get_action(self, x, deterministic=True):
+        mean = self.actor_mean(x)
+        if deterministic:
+            return mean
+        logstd = self.actor_logstd.expand_as(mean)
+        std = torch.exp(logstd)
+        return mean + std * torch.randn_like(mean)
+
+
+# ---------------------------------------------------------------------------
+# Environment builder — must use the same wrappers as training
+# ---------------------------------------------------------------------------
+
+def make_eval_env(env_id: str, render: bool, seed: int):
+    render_mode = "human" if render else None
+    env = gym.make(env_id, render_mode=render_mode)
+    env = gym.wrappers.FlattenObservation(env)
+    env = gym.wrappers.ClipAction(env)
+    env = gym.wrappers.NormalizeObservation(env)
+    env = gym.wrappers.TransformObservation(
+        env,
+        lambda obs: np.clip(obs, -10, 10),
+        observation_space=env.observation_space,
+    )
+    env.reset(seed=seed)
+    return env
+
+
+# ---------------------------------------------------------------------------
+# Main
+# ---------------------------------------------------------------------------
+
+def main():
+    parser = argparse.ArgumentParser()
+    parser.add_argument("--model-path", type=str, required=True,
+                        help="Path to the .cleanrl_model file saved during training")
+    parser.add_argument("--env-id", type=str, default="PupperNavEnv-v0",
+                        help="Gymnasium env ID to evaluate on (must match training env)")
+    parser.add_argument("--num-episodes", type=int, default=5,
+                        help="Number of evaluation episodes")
+    parser.add_argument("--deterministic", type=bool, default=True,
+                        help="Use mean action (True) or sample from policy (False)")
+    parser.add_argument("--no-render", action="store_true",
+                        help="Disable PyBullet GUI (run headless)")
+    parser.add_argument("--seed", type=int, default=42)
+    args = parser.parse_args()
+
+    if not os.path.exists(args.model_path):
+        raise FileNotFoundError(f"Model not found: {args.model_path}")
+
+    render = not args.no_render
+    device = torch.device("cpu")  # eval on CPU is fine
+
+    env = make_eval_env(env_id=args.env_id, render=render, seed=args.seed)
+
+    obs_dim = int(np.prod(env.observation_space.shape))
+    action_dim = int(np.prod(env.action_space.shape))
+
+    # Load weights — handle both old format (bare state_dict) and new format (dict with "agent" key)
+    checkpoint = torch.load(args.model_path, map_location=device)
+    agent = Agent(obs_dim, action_dim).to(device)
+    if isinstance(checkpoint, dict) and "agent" in checkpoint:
+        agent.load_state_dict(checkpoint["agent"])
+    else:
+        agent.load_state_dict(checkpoint)
+    agent.eval()
+
+    print(f"\nEvaluating {args.num_episodes} episodes — {'deterministic' if args.deterministic else 'stochastic'}")
+    print(f"Model: {args.model_path}\n")
+
+    episode_returns = []
+    episode_lengths = []
+
+    for ep in range(args.num_episodes):
+        obs, _ = env.reset()
+        ep_return = 0.0
+        ep_length = 0
+        done = False
+
+        while not done:
+            obs_tensor = torch.tensor(obs, dtype=torch.float32, device=device).unsqueeze(0)
+            with torch.no_grad():
+                action = agent.get_action(obs_tensor, deterministic=args.deterministic)
+            action_np = action.squeeze(0).cpu().numpy()
+
+            obs, reward, terminated, truncated, _ = env.step(action_np)
+            done = terminated or truncated
+            ep_return += reward
+            ep_length += 1
+
+            if render:
+                time.sleep(0.01)  # slow down to ~real-time for visualization
+
+        episode_returns.append(ep_return)
+        episode_lengths.append(ep_length)
+        print(f"  Episode {ep + 1:2d}: return = {ep_return:8.3f}, length = {ep_length}")
+
+    print(f"\nSummary over {args.num_episodes} episodes:")
+    print(f"  Mean return : {np.mean(episode_returns):.3f} ± {np.std(episode_returns):.3f}")
+    print(f"  Mean length : {np.mean(episode_lengths):.1f}")
+
+    env.close()
+
+
+if __name__ == "__main__":
+    main()
