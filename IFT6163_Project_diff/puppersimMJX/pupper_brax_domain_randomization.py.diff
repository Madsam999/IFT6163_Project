+"""Domain randomization utilities for Pupper Brax/MJX training."""
+
+from __future__ import annotations
+
+from dataclasses import dataclass
+from typing import Tuple
+
+import jax
+from jax import numpy as jp
+
+
+def domain_randomize(
+    sys,
+    rng,
+    friction_range: Tuple[float, float] = (0.6, 1.4),
+    kp_multiplier_range: Tuple[float, float] = (0.75, 1.25),
+    kd_multiplier_range: Tuple[float, float] = (0.5, 2.0),
+    body_com_x_shift_range: Tuple[float, float] = (-0.03, 0.03),
+    body_com_y_shift_range: Tuple[float, float] = (-0.01, 0.01),
+    body_com_z_shift_range: Tuple[float, float] = (-0.02, 0.02),
+    body_inertia_scale_range: Tuple[float, float] = (0.7, 1.3),
+    body_mass_scale_range: Tuple[float, float] = (0.7, 1.3),
+):
+    """Randomizes friction, actuator gains, COM, inertia, and mass.
+
+    Returns `(sys_batched, in_axes)` compatible with Brax PPO randomization_fn.
+    """
+
+    @jax.vmap
+    def rand(one_rng):
+        one_rng, key = jax.random.split(one_rng, 2)
+        # geom friction (linear term only)
+        friction = jax.random.uniform(key, (1,), minval=friction_range[0], maxval=friction_range[1])
+        friction = sys.geom_friction.at[:, 0].set(friction)
+
+        # actuator kp/kd multipliers
+        one_rng, key_kp, key_kd = jax.random.split(one_rng, 3)
+        kp = (
+            jax.random.uniform(key_kp, (1,), minval=kp_multiplier_range[0], maxval=kp_multiplier_range[1])
+            * sys.actuator_gainprm[:, 0]
+        )
+        kd = (
+            jax.random.uniform(key_kd, (1,), minval=kd_multiplier_range[0], maxval=kd_multiplier_range[1])
+            * (-sys.actuator_biasprm[:, 2])
+        )
+        gain = sys.actuator_gainprm.at[:, 0].set(kp)
+        bias = sys.actuator_biasprm.at[:, 1].set(-kp).at[:, 2].set(-kd)
+
+        # base COM shift (body index 1: base_link, index 0 is world body)
+        one_rng, key_com = jax.random.split(one_rng)
+        body_com_shift = jax.random.uniform(
+            key_com,
+            (3,),
+            minval=jp.array(
+                [body_com_x_shift_range[0], body_com_y_shift_range[0], body_com_z_shift_range[0]]
+            ),
+            maxval=jp.array(
+                [body_com_x_shift_range[1], body_com_y_shift_range[1], body_com_z_shift_range[1]]
+            ),
+        )
+        body_com = sys.body_ipos.at[1].set(sys.body_ipos[1] + body_com_shift)
+
+        # per-body inertia and mass scaling
+        one_rng, key_inertia = jax.random.split(one_rng)
+        body_inertia_scale = jax.random.uniform(
+            key_inertia,
+            sys.body_inertia.shape,
+            minval=body_inertia_scale_range[0],
+            maxval=body_inertia_scale_range[1],
+        )
+        body_inertia = sys.body_inertia * body_inertia_scale
+
+        one_rng, key_mass = jax.random.split(one_rng)
+        body_mass_scale = jax.random.uniform(
+            key_mass,
+            sys.body_mass.shape,
+            minval=body_mass_scale_range[0],
+            maxval=body_mass_scale_range[1],
+        )
+        body_mass = sys.body_mass * body_mass_scale
+
+        return friction, gain, bias, body_com, body_inertia, body_mass
+
+    friction, gain, bias, body_com, body_inertia, body_mass = rand(rng)
+
+    in_axes = jax.tree_util.tree_map(lambda _: None, sys)
+    in_axes = in_axes.tree_replace(
+        {
+            "geom_friction": 0,
+            "actuator_gainprm": 0,
+            "actuator_biasprm": 0,
+            "body_ipos": 0,
+            "body_inertia": 0,
+            "body_mass": 0,
+        }
+    )
+
+    sys = sys.tree_replace(
+        {
+            "geom_friction": friction,
+            "actuator_gainprm": gain,
+            "actuator_biasprm": bias,
+            "body_ipos": body_com,
+            "body_inertia": body_inertia,
+            "body_mass": body_mass,
+        }
+    )
+    return sys, in_axes
+
+
+@dataclass
+class StartPositionRandomization:
+    x_min: float
+    x_max: float
+    y_min: float
+    y_max: float
+    z_min: float
+    z_max: float
+
+
+def small_quaternion(rng, max_angle_deg: float = 30.0, max_yaw_deg: float = 180.0):
+    """Returns a quaternion (w, x, y, z) with random pitch/roll/yaw."""
+    _, key_pitch, key_roll, key_yaw = jax.random.split(rng, 4)
+    pitch_deg = (jax.random.uniform(key_pitch, ()) * 2.0 - 1.0) * max_angle_deg
+    roll_deg = (jax.random.uniform(key_roll, ()) * 2.0 - 1.0) * max_angle_deg
+    yaw_deg = (jax.random.uniform(key_yaw, ()) * 2.0 - 1.0) * max_yaw_deg
+
+    pitch_rad = pitch_deg * jp.pi / 180.0
+    roll_rad = roll_deg * jp.pi / 180.0
+    yaw_rad = yaw_deg * jp.pi / 180.0
+
+    cr = jp.cos(roll_rad / 2.0)
+    sr = jp.sin(roll_rad / 2.0)
+    cp = jp.cos(pitch_rad / 2.0)
+    sp = jp.sin(pitch_rad / 2.0)
+    cy = jp.cos(yaw_rad / 2.0)
+    sy = jp.sin(yaw_rad / 2.0)
+
+    w = cr * cp * cy + sr * sp * sy
+    x = sr * cp * cy - cr * sp * sy
+    y = cr * sp * cy + sr * cp * sy
+    z = cr * cp * sy - sr * sp * cy
+    q = jp.array([w, x, y, z])
+    return q / jp.linalg.norm(q)
+
+
+def random_z_rotation_quaternion(rng):
+    """Generates a random yaw-only quaternion (w, x, y, z)."""
+    yaw = jax.random.uniform(rng, (1,), minval=-jp.pi, maxval=jp.pi)
+    cos_yaw = jp.cos(yaw / 2.0)
+    sin_yaw = jp.sin(yaw / 2.0)
+    return jp.concatenate((cos_yaw, jp.zeros(2), sin_yaw))
+
+
+def randomize_qpos(qpos: jp.ndarray, start_position_config: StartPositionRandomization, rng):
+    """Returns qpos with randomized base xyz and yaw."""
+    _, _, _, key_xyz, key_yaw = jax.random.split(rng, 5)
+    qpos = qpos.at[:3].set(
+        jax.random.uniform(
+            key_xyz,
+            shape=(3,),
+            minval=jp.array(
+                (start_position_config.x_min, start_position_config.y_min, start_position_config.z_min)
+            ),
+            maxval=jp.array(
+                (start_position_config.x_max, start_position_config.y_max, start_position_config.z_max)
+            ),
+        )
+    )
+    qpos = qpos.at[3:7].set(random_z_rotation_quaternion(key_yaw))
+    return qpos
+
